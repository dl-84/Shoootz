<UserControl x:Class="Shoootz.Views.Competition.EvaluationView"
             xmlns="https://github.com/avaloniaui"
             xmlns:loc="using:Shoootz.Extensions"
             xmlns:vm="using:Shoootz.ViewModels.Competition"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:DataType="vm:EvaluationViewModel">
    <ScrollViewer>
        <StackPanel Classes="page-content">
            <TextBlock Classes="h3"
                       Text="{loc:Localization Evaluate}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
