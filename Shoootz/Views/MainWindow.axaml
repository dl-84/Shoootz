<Window x:Class="Shoootz.Views.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:loc="using:Shoootz.Extensions"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tb="using:Controls.TitleBar"
        xmlns:vm="using:Shoootz.ViewModels"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:DataType="vm:MainWindowViewModel"
        Background="Transparent"
        ExtendClientAreaTitleBarHeightHint="-1"
        ExtendClientAreaToDecorationsHint="True"
        Height="750"
        Icon="/Assets/Disag/Logo.png"
        MinHeight="750"
        MinWidth="1200"
        Title="Shoootz"
        TransparencyLevelHint="Transparent"
        Width="1200"
        WindowDecorations="None"
        d:DesignHeight="750"
        d:DesignWidth="1200"
        mc:Ignorable="d">

    <Border x:Name="RootBorder"
            ClipToBounds="True"
            CornerRadius="10">
        <DockPanel>

            <tb:TitleBarControl BackgroundColor="{DynamicResource AppBackgroundAltBrush}"
                                PrimaryColor="{DynamicResource PrimaryBrush}" />

            <Grid ColumnDefinitions="220,*">

                <!--  Sidebar  -->
                <Border Grid.Column="0"
                        Background="{DynamicResource PrimaryBrush}">
                    <ListBox Classes="nav"
                             Margin="0,16,0,0"
                             SelectedIndex="{Binding ActiveIndex}">

                        <!--  Competition  -->
                        <ListBoxItem Classes="nav-header"
                                     IsEnabled="False">
                            <TextBlock Classes="label"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextOnDarkBrush}"
                                       Margin="20,16,20,4"
                                       Opacity="0.4"
                                       Text="{loc:Localization Competition}" />
                        </ListBoxItem>
                        <ListBoxItem IsEnabled="{Binding !HasSettingsErrors}">
                            <TextBlock FontSize="16"
                                       Foreground="{DynamicResource TextOnDarkBrush}"
                                       Text="{loc:Localization Evaluate}" />
                        </ListBoxItem>

                        <!--  Settings  -->
                        <ListBoxItem Classes="nav-header"
                                     IsEnabled="False">
                            <TextBlock Classes="label"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextOnDarkBrush}"
                                       Margin="20,28,20,4"
                                       Opacity="0.4"
                                       Text="{loc:Localization Settings}" />
                        </ListBoxItem>
                        <ListBoxItem>
                            <TextBlock FontSize="16"
                                       Foreground="{DynamicResource TextOnDarkBrush}"
                                       Text="{loc:Localization General}" />
                        </ListBoxItem>
                        <ListBoxItem IsEnabled="{Binding !HasSettingsErrors}">
                            <TextBlock FontSize="16"
                                       Foreground="{DynamicResource TextOnDarkBrush}"
                                       Text="{loc:Localization Database}" />
                        </ListBoxItem>
                        <ListBoxItem IsEnabled="{Binding !HasSettingsErrors}">
                            <TextBlock FontSize="16"
                                       Foreground="{DynamicResource TextOnDarkBrush}"
                                       Text="{loc:Localization Groups}" />
                        </ListBoxItem>

                        <!--  Info  -->
                        <ListBoxItem Classes="nav-header"
                                     IsEnabled="False">
                            <TextBlock Classes="label"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextOnDarkBrush}"
                                       Margin="20,28,20,4"
                                       Opacity="0.4"
                                       Text="{loc:Localization Info}" />
                        </ListBoxItem>
                        <ListBoxItem IsEnabled="{Binding !HasSettingsErrors}">
                            <TextBlock FontSize="16"
                                       Foreground="{DynamicResource TextOnDarkBrush}"
                                       Text="{loc:Localization About}" />
                        </ListBoxItem>
                        <ListBoxItem IsEnabled="{Binding !HasSettingsErrors}">
                            <TextBlock FontSize="16"
                                       Foreground="{DynamicResource TextOnDarkBrush}"
                                       Text="{loc:Localization Licenses}" />
                        </ListBoxItem>

                    </ListBox>
                </Border>

                <!--  Content Area  -->
                <ContentControl Grid.Column="1"
                                Background="{DynamicResource AppBackgroundAltBrush}"
                                Content="{Binding CurrentPage}" />

            </Grid>
        </DockPanel>
    </Border>
</Window>
