<Window x:Class="Shoootz.Views.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:loc="using:Shoootz.Extensions"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Shoootz.ViewModels"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:DataType="vm:MainWindowViewModel"
        Background="Transparent"
        Height="750"
        Icon="/Assets/Disag/Logo.png"
        MinHeight="750"
        MinWidth="1200"
        Title="Shoootz"
        TransparencyLevelHint="Transparent"
        Width="1200"
        WindowDecorations="None"
        d:DesignHeight="750"
        d:DesignWidth="1200"
        mc:Ignorable="d">

    <Window.Resources>

        <ControlTheme x:Key="WindowControlButton"
                      TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource PrimaryHoverBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource TextOnDarkBrush}" />
            <Setter Property="Height" Value="36" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Width" Value="36" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="0">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          Foreground="{DynamicResource TextOnDarkBrush}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ Border#Root">
                <Setter Property="Background" Value="#1AFFFFFF" />
            </Style>
            <Style Selector="^:pressed /template/ Border#Root">
                <Setter Property="Background" Value="#33FFFFFF" />
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="WindowCloseButton"
                      BasedOn="{StaticResource WindowControlButton}"
                      TargetType="Button">
            <Style Selector="^:pointerover /template/ Border#Root">
                <Setter Property="Background" Value="#C42B1C" />
            </Style>
            <Style Selector="^:pressed /template/ Border#Root">
                <Setter Property="Background" Value="#9B2318" />
            </Style>
        </ControlTheme>

    </Window.Resources>

    <Border ClipToBounds="True"
            CornerRadius="10">
        <Grid ColumnDefinitions="220,*"
              RowDefinitions="36,*">

            <!--  Title Bar Left (Navbar width)  -->
            <Border Grid.Row="0"
                    Grid.Column="0"
                    Background="{DynamicResource PrimaryBrush}">
                <StackPanel x:Name="MacOsButtons"
                            Margin="14,0,0,0"
                            Orientation="Horizontal"
                            PointerEntered="OnMacButtonsPointerEntered"
                            PointerExited="OnMacButtonsPointerExited"
                            Spacing="10"
                            VerticalAlignment="Center">
                    <Border Background="#FF5C5F"
                            CornerRadius="6"
                            Cursor="Hand"
                            Height="12"
                            PointerPressed="OnMacCloseClicked"
                            Width="12">
                        <Path x:Name="MacCloseIcon"
                              Data="M0,0 L5,5 M5,0 L0,5"
                              Height="5"
                              HorizontalAlignment="Center"
                              IsHitTestVisible="False"
                              Opacity="0"
                              Stretch="None"
                              Stroke="#9B1B0F"
                              StrokeLineCap="Round"
                              StrokeThickness="1.75"
                              VerticalAlignment="Center"
                              Width="5" />
                    </Border>
                    <Border Background="#FFC800"
                            CornerRadius="6"
                            Cursor="Hand"
                            Height="12"
                            PointerPressed="OnMacMinimizeClicked"
                            Width="12">
                        <Path x:Name="MacMinimizeIcon"
                              Data="M0,1 L6,1"
                              Height="2"
                              HorizontalAlignment="Center"
                              IsHitTestVisible="False"
                              Opacity="0"
                              Stretch="None"
                              Stroke="#9B6200"
                              StrokeLineCap="Round"
                              StrokeThickness="1.75"
                              VerticalAlignment="Center"
                              Width="6" />
                    </Border>
                    <Border x:Name="MacMaximizeBorder"
                            Background="#35C759"
                            CornerRadius="6"
                            Cursor="Hand"
                            Height="12"
                            PointerPressed="OnMacMaximizeClicked"
                            Width="12">
                        <Path x:Name="MacMaximizeIcon"
                              Data="M1,6 L6,1 M4,1 L6,1 L6,3 M1,4 L1,6 L3,6"
                              Height="7"
                              HorizontalAlignment="Center"
                              IsHitTestVisible="False"
                              Opacity="0"
                              Stretch="None"
                              Stroke="#0B6B1F"
                              StrokeLineCap="Round"
                              StrokeThickness="1.75"
                              VerticalAlignment="Center"
                              Width="7" />
                    </Border>
                </StackPanel>
            </Border>

            <!--  Title Bar Right (Content width)  -->
            <Border Grid.Row="0"
                    Grid.Column="1"
                    Background="{DynamicResource AppBackgroundAltBrush}">
                <Grid ColumnDefinitions="*,Auto">
                    <Panel Grid.Column="0"
                           Background="Transparent"
                           Cursor="Hand"
                           PointerPressed="OnTitleBarDrag" />
                    <StackPanel x:Name="WindowControlButtons"
                                Grid.Column="1"
                                Orientation="Horizontal">
                        <Button Click="OnMinimizeClicked"
                                MinWidth="0"
                                Theme="{StaticResource WindowControlButton}"
                                Width="50">
                            <TextBlock Foreground="{DynamicResource TextOnDarkBrush}"
                                       Text="─" />
                        </Button>
                        <Button Click="OnMaximizeRestoreClicked"
                                MinWidth="0"
                                Theme="{StaticResource WindowControlButton}"
                                Width="50">
                            <Path x:Name="MaximizeIcon"
                                  Data="M0,0 H11 V11 H0 Z"
                                  HorizontalAlignment="Center"
                                  Stroke="{DynamicResource TextOnDarkBrush}"
                                  StrokeThickness="1.5"
                                  VerticalAlignment="Center" />
                        </Button>
                        <Button Click="OnCloseClicked"
                                MinWidth="0"
                                Theme="{StaticResource WindowCloseButton}"
                                Width="50">
                            <TextBlock Foreground="{DynamicResource TextOnDarkBrush}"
                                       Text="✕" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!--  Sidebar  -->
            <Border Grid.Row="1"
                    Grid.Column="0"
                    Background="{DynamicResource PrimaryBrush}">
                <ListBox Background="Transparent"
                         BorderThickness="0"
                         Margin="0,16,0,0"
                         Padding="0"
                         SelectedIndex="{Binding ActiveIndex}">

                    <ListBox.Styles>
                        <Style Selector="ListBoxItem:selected ContentPresenter">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="CornerRadius" Value="0" />
                        </Style>
                        <Style Selector="ListBoxItem:pointerover ContentPresenter">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="CornerRadius" Value="0" />
                        </Style>
                        <Style Selector="ListBoxItem:selected:pointerover ContentPresenter">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="CornerRadius" Value="0" />
                        </Style>
                    </ListBox.Styles>

                    <ListBox.Resources>
                        <ControlTheme x:Key="{x:Type ListBoxItem}"
                                      TargetType="ListBoxItem">
                            <Setter Property="Cursor" Value="Hand" />
                            <Setter Property="FocusAdorner" Value="{x:Null}" />
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                            <Setter Property="Template">
                                <ControlTemplate>
                                    <Border x:Name="Root"
                                            Background="{DynamicResource PrimaryBrush}"
                                            BorderBrush="Transparent"
                                            BorderThickness="3,0,0,0"
                                            Opacity="0.7"
                                            Padding="28,12,20,12">
                                        <ContentPresenter Background="Transparent"
                                                          Content="{TemplateBinding Content}"
                                                          HorizontalAlignment="Left"
                                                          VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Setter>
                            <Style Selector="^:pointerover /template/ Border#Root">
                                <Setter Property="Background" Value="#1AFFFFFF" />
                                <Setter Property="Opacity" Value="0.9" />
                            </Style>
                            <Style Selector="^:selected /template/ Border#Root">
                                <Setter Property="Background" Value="#2E019DC6" />
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Opacity" Value="1" />
                            </Style>
                            <Style Selector="^:selected:pointerover /template/ Border#Root">
                                <Setter Property="Background" Value="#2E019DC6" />
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Opacity" Value="1" />
                            </Style>
                            <Style Selector="^.nav-header">
                                <Setter Property="Cursor" Value="Arrow" />
                                <Setter Property="Template">
                                    <ControlTemplate>
                                        <ContentPresenter Content="{TemplateBinding Content}" />
                                    </ControlTemplate>
                                </Setter>
                            </Style>
                        </ControlTheme>
                    </ListBox.Resources>

                    <!--  Competition  -->
                    <ListBoxItem Classes="nav-header"
                                 IsEnabled="False">
                        <TextBlock Classes="label"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextOnDarkBrush}"
                                   Margin="20,16,20,4"
                                   Opacity="0.4"
                                   Text="{loc:Localization Competition}" />
                    </ListBoxItem>
                    <ListBoxItem IsEnabled="{Binding !HasSettingsErrors}">
                        <TextBlock FontSize="16"
                                   Foreground="{DynamicResource TextOnDarkBrush}"
                                   Text="{loc:Localization Evaluate}" />
                    </ListBoxItem>

                    <!--  Settings  -->
                    <ListBoxItem Classes="nav-header"
                                 IsEnabled="False">
                        <TextBlock Classes="label"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextOnDarkBrush}"
                                   Margin="20,28,20,4"
                                   Opacity="0.4"
                                   Text="{loc:Localization Settings}" />
                    </ListBoxItem>
                    <ListBoxItem>
                        <TextBlock FontSize="16"
                                   Foreground="{DynamicResource TextOnDarkBrush}"
                                   Text="{loc:Localization General}" />
                    </ListBoxItem>
                    <ListBoxItem IsEnabled="{Binding !HasSettingsErrors}">
                        <TextBlock FontSize="16"
                                   Foreground="{DynamicResource TextOnDarkBrush}"
                                   Text="{loc:Localization Database}" />
                    </ListBoxItem>
                    <ListBoxItem IsEnabled="{Binding !HasSettingsErrors}">
                        <TextBlock FontSize="16"
                                   Foreground="{DynamicResource TextOnDarkBrush}"
                                   Text="{loc:Localization Groups}" />
                    </ListBoxItem>

                    <!--  Info  -->
                    <ListBoxItem Classes="nav-header"
                                 IsEnabled="False">
                        <TextBlock Classes="label"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextOnDarkBrush}"
                                   Margin="20,28,20,4"
                                   Opacity="0.4"
                                   Text="{loc:Localization Info}" />
                    </ListBoxItem>
                    <ListBoxItem IsEnabled="{Binding !HasSettingsErrors}">
                        <TextBlock FontSize="16"
                                   Foreground="{DynamicResource TextOnDarkBrush}"
                                   Text="{loc:Localization About}" />
                    </ListBoxItem>
                    <ListBoxItem IsEnabled="{Binding !HasSettingsErrors}">
                        <TextBlock FontSize="16"
                                   Foreground="{DynamicResource TextOnDarkBrush}"
                                   Text="{loc:Localization Licenses}" />
                    </ListBoxItem>

                </ListBox>
            </Border>

            <!--  Content Area  -->
            <ContentControl Grid.Row="1"
                            Grid.Column="1"
                            Background="{DynamicResource AppBackgroundAltBrush}"
                            Content="{Binding CurrentPage}" />

        </Grid>
    </Border>
</Window>
