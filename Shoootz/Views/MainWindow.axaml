<Window x:Class="Shoootz.Views.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:loc="using:Shoootz.Extensions"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tb="using:Controls.TitleBar"
        xmlns:vm="using:Shoootz.ViewModels"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:DataType="vm:MainWindowViewModel"
        Background="Transparent"
        ExtendClientAreaTitleBarHeightHint="-1"
        ExtendClientAreaToDecorationsHint="True"
        Height="750"
        Icon="/Assets/Disag/Logo.png"
        MinHeight="750"
        MinWidth="1200"
        Title="Shoootz"
        TransparencyLevelHint="Transparent"
        Width="1200"
        WindowDecorations="BorderOnly"
        d:DesignHeight="750"
        d:DesignWidth="1200"
        mc:Ignorable="d">

    <Window.Styles>
        <Style Selector="Border.status-pill">
            <Setter Property="Background" Value="{DynamicResource ErrorBrush}" />
        </Style>
        <Style Selector="Border.status-pill.connected">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}" />
        </Style>
    </Window.Styles>

    <Border x:Name="RootBorder"
            ClipToBounds="True"
            CornerRadius="10">
        <Panel>
            <DockPanel>

                <tb:TitleBarControl />

                <Grid ColumnDefinitions="220,*">

                    <!--  Sidebar  -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource PrimaryBrush}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Bottom"
                                        Margin="20,16,20,20"
                                        Spacing="8">
                                <Border Classes="status-pill"
                                        Classes.connected="{Binding IsDbConnected}"
                                        CornerRadius="6"
                                        Padding="12,6">
                                    <TextBlock FontSize="13"
                                               Foreground="{DynamicResource TextWhiteBrush}"
                                               HorizontalAlignment="Center"
                                               Text="{Binding DbBadgeText}"
                                               TextAlignment="Center" />
                                </Border>
                                <Border Classes="status-pill"
                                        Classes.connected="{Binding IsUdpConnected}"
                                        CornerRadius="6"
                                        Padding="12,6">
                                    <TextBlock FontSize="13"
                                               Foreground="{DynamicResource TextWhiteBrush}"
                                               HorizontalAlignment="Center"
                                               Text="{Binding UdpBadgeText}"
                                               TextAlignment="Center" />
                                </Border>
                            </StackPanel>
                            <ListBox Classes="nav"
                                     ItemContainerTheme="{DynamicResource NavigationItem}"
                                     Margin="0,16,0,0"
                                     SelectedIndex="{Binding ActiveIndex}"
                                     IsEnabled="{Binding IsNavbarEnabled}">

                                <!--  Competition  -->
                                <ListBoxItem Classes="navigation-header"
                                             IsEnabled="False">
                                    <TextBlock Margin="20,16,20,4"
                                               Text="{loc:Localization Competition,
                                                                       ToUpper=True}" />
                                </ListBoxItem>
                                <ListBoxItem>
                                    <TextBlock Text="{loc:Localization Evaluate}" />
                                </ListBoxItem>

                                <!--  Settings  -->
                                <ListBoxItem Classes="navigation-header"
                                             IsEnabled="False">
                                    <TextBlock Margin="20,28,20,4"
                                               Text="{loc:Localization Settings,
                                                                       ToUpper=True}" />
                                </ListBoxItem>
                                <ListBoxItem>
                                    <TextBlock Text="{loc:Localization General}" />
                                </ListBoxItem>
                                <ListBoxItem>
                                    <TextBlock Text="{loc:Localization Database}" />
                                </ListBoxItem>
                                <ListBoxItem>
                                    <TextBlock Text="{loc:Localization Groups}" />
                                </ListBoxItem>

                                <!--  Info  -->
                                <ListBoxItem Classes="navigation-header"
                                             IsEnabled="False">
                                    <TextBlock Margin="20,28,20,4"
                                               Text="{loc:Localization Info,
                                                                       ToUpper=True}" />
                                </ListBoxItem>
                                <ListBoxItem>
                                    <TextBlock Text="{loc:Localization About}" />
                                </ListBoxItem>
                                <ListBoxItem>
                                    <TextBlock Text="{loc:Localization Licenses}" />
                                </ListBoxItem>

                            </ListBox>
                        </DockPanel>
                    </Border>

                    <!--  Content Area  -->
                    <ContentControl Grid.Column="1"
                                    Background="{DynamicResource AppBackgroundAltBrush}"
                                    Content="{Binding CurrentPage}" />

                </Grid>
            </DockPanel>
            <Border Background="{DynamicResource OverlayBrush}"
                    IsVisible="{Binding IsDialogOpen}" />
        </Panel>
    </Border>
</Window>
