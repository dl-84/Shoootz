<Window x:Class="Shoootz.Views.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:loc="using:Shoootz.Extensions"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:tb="using:Controls.TitleBar"
        xmlns:vm="using:Shoootz.ViewModels"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:DataType="vm:MainWindowViewModel"
        Background="Transparent"
        ExtendClientAreaTitleBarHeightHint="-1"
        ExtendClientAreaToDecorationsHint="True"
        Height="750"
        Icon="/Assets/Disag/Logo.png"
        MinHeight="750"
        MinWidth="1200"
        Title="Shoootz"
        TransparencyLevelHint="Transparent"
        Width="1200"
        WindowDecorations="None"
        d:DesignHeight="750"
        d:DesignWidth="1200"
        mc:Ignorable="d">

    <Border x:Name="RootBorder"
            ClipToBounds="True"
            CornerRadius="10">
        <Panel>
            <DockPanel>

                <tb:TitleBarControl BackgroundColor="{DynamicResource AppBackgroundAltBrush}"
                                    PrimaryColor="{DynamicResource PrimaryBrush}" />

                <Grid ColumnDefinitions="220,*">

                    <!--  Sidebar  -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource PrimaryBrush}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Bottom"
                                        Margin="20,16"
                                        Spacing="8">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="6"
                                            VerticalAlignment="Center">
                                    <Ellipse Fill="{DynamicResource AccentGreenBrush}"
                                             Height="8"
                                             VerticalAlignment="Center"
                                             Width="8" />
                                    <TextBlock FontSize="11"
                                               Foreground="{DynamicResource FooterForegroundBrush}"
                                               Text="{loc:Localization Database}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="6"
                                            VerticalAlignment="Center">
                                    <Ellipse Fill="{DynamicResource ErrorBrush}"
                                             Height="8"
                                             VerticalAlignment="Center"
                                             Width="8" />
                                    <TextBlock FontSize="11"
                                               Foreground="{DynamicResource FooterForegroundBrush}"
                                               Text="UNC Broadcast"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </StackPanel>
                            <ListBox Classes="nav"
                                     ItemContainerTheme="{DynamicResource NavigationItem}"
                                     Margin="0,16,0,0"
                                     SelectedIndex="{Binding ActiveIndex}"
                                     IsEnabled="{Binding IsNavbarEnabled}">

                                <!--  Competition  -->
                                <ListBoxItem Classes="navigation-header"
                                             IsEnabled="False">
                                    <TextBlock Margin="20,16,20,4"
                                               Text="{loc:Localization Competition,
                                                                       ToUpper=True}" />
                                </ListBoxItem>
                                <ListBoxItem>
                                    <TextBlock Text="{loc:Localization Evaluate}" />
                                </ListBoxItem>

                                <!--  Settings  -->
                                <ListBoxItem Classes="navigation-header"
                                             IsEnabled="False">
                                    <TextBlock Margin="20,28,20,4"
                                               Text="{loc:Localization Settings,
                                                                       ToUpper=True}" />
                                </ListBoxItem>
                                <ListBoxItem>
                                    <TextBlock Text="{loc:Localization General}" />
                                </ListBoxItem>
                                <ListBoxItem>
                                    <TextBlock Text="{loc:Localization Database}" />
                                </ListBoxItem>
                                <ListBoxItem>
                                    <TextBlock Text="{loc:Localization Groups}" />
                                </ListBoxItem>

                                <!--  Info  -->
                                <ListBoxItem Classes="navigation-header"
                                             IsEnabled="False">
                                    <TextBlock Margin="20,28,20,4"
                                               Text="{loc:Localization Info,
                                                                       ToUpper=True}" />
                                </ListBoxItem>
                                <ListBoxItem>
                                    <TextBlock Text="{loc:Localization About}" />
                                </ListBoxItem>
                                <ListBoxItem>
                                    <TextBlock Text="{loc:Localization Licenses}" />
                                </ListBoxItem>

                            </ListBox>
                        </DockPanel>
                    </Border>

                    <!--  Content Area  -->
                    <ContentControl Grid.Column="1"
                                    Background="{DynamicResource AppBackgroundAltBrush}"
                                    Content="{Binding CurrentPage}" />

                </Grid>
            </DockPanel>
            <Border Background="{DynamicResource OverlayBrush}"
                    IsVisible="{Binding IsDialogOpen}" />
        </Panel>
    </Border>
</Window>
