<Window x:Class="Shoootz.Views.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:loc="using:Shoootz.Extensions"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Shoootz.ViewModels"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:DataType="vm:MainWindowViewModel"
        Height="750"
        Icon="/Assets/Disag/Logo.png"
        MinHeight="600"
        MinWidth="900"
        Title="Shoootz"
        Width="1200"
        d:DesignHeight="750"
        d:DesignWidth="1200"
        mc:Ignorable="d">

    <Grid ColumnDefinitions="220,*">

        <!--  Sidebar  -->
        <Border Grid.Column="0"
                Background="{DynamicResource PrimaryBrush}">
            <ListBox Background="Transparent"
                     BorderThickness="0"
                     Margin="0,16,0,0"
                     Padding="0"
                     SelectedIndex="{Binding ActiveIndex}">

                <ListBox.Styles>
                    <Style Selector="ListBoxItem:selected ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="CornerRadius" Value="0" />
                    </Style>
                    <Style Selector="ListBoxItem:pointerover ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="CornerRadius" Value="0" />
                    </Style>
                    <Style Selector="ListBoxItem:selected:pointerover ContentPresenter">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="CornerRadius" Value="0" />
                    </Style>
                </ListBox.Styles>

                <ListBox.Resources>
                    <ControlTheme x:Key="{x:Type ListBoxItem}"
                                  TargetType="ListBoxItem">
                        <Setter Property="Cursor" Value="Hand" />
                        <Setter Property="FocusAdorner" Value="{x:Null}" />
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <ControlTemplate>
                                <Border x:Name="Root"
                                        Background="{DynamicResource PrimaryBrush}"
                                        BorderBrush="Transparent"
                                        BorderThickness="3,0,0,0"
                                        Opacity="0.7"
                                        Padding="28,12,20,12">
                                    <ContentPresenter Background="Transparent"
                                                      Content="{TemplateBinding Content}"
                                                      HorizontalAlignment="Left"
                                                      VerticalAlignment="Center" />
                                </Border>
                            </ControlTemplate>
                        </Setter>
                        <Style Selector="^:pointerover /template/ Border#Root">
                            <Setter Property="Background" Value="#1AFFFFFF" />
                            <Setter Property="Opacity" Value="0.9" />
                        </Style>
                        <Style Selector="^:selected /template/ Border#Root">
                            <Setter Property="Background" Value="#2E019DC6" />
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Setter Property="Opacity" Value="1" />
                        </Style>
                        <Style Selector="^:selected:pointerover /template/ Border#Root">
                            <Setter Property="Background" Value="#2E019DC6" />
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                            <Setter Property="Opacity" Value="1" />
                        </Style>
                        <Style Selector="^.nav-header">
                            <Setter Property="Cursor" Value="Arrow" />
                            <Setter Property="Template">
                                <ControlTemplate>
                                    <ContentPresenter Content="{TemplateBinding Content}" />
                                </ControlTemplate>
                            </Setter>
                        </Style>
                    </ControlTheme>
                </ListBox.Resources>

                <!--  Competition  -->
                <ListBoxItem Classes="nav-header"
                             IsEnabled="False">
                    <TextBlock Classes="label"
                               FontSize="13"
                               Foreground="{DynamicResource TextOnDarkBrush}"
                               Margin="20,16,20,4"
                               Opacity="0.4"
                               Text="{loc:Localization Competition}" />
                </ListBoxItem>
                <ListBoxItem IsEnabled="{Binding !HasSettingsErrors}">
                    <TextBlock FontSize="16"
                               Foreground="{DynamicResource TextOnDarkBrush}"
                               Text="{loc:Localization Evaluate}" />
                </ListBoxItem>

                <!--  Settings  -->
                <ListBoxItem Classes="nav-header"
                             IsEnabled="False">
                    <TextBlock Classes="label"
                               FontSize="13"
                               Foreground="{DynamicResource TextOnDarkBrush}"
                               Margin="20,28,20,4"
                               Opacity="0.4"
                               Text="{loc:Localization Settings}" />
                </ListBoxItem>
                <ListBoxItem>
                    <TextBlock FontSize="16"
                               Foreground="{DynamicResource TextOnDarkBrush}"
                               Text="{loc:Localization General}" />
                </ListBoxItem>
                <ListBoxItem IsEnabled="{Binding !HasSettingsErrors}">
                    <TextBlock FontSize="16"
                               Foreground="{DynamicResource TextOnDarkBrush}"
                               Text="{loc:Localization Database}" />
                </ListBoxItem>
                <ListBoxItem IsEnabled="{Binding !HasSettingsErrors}">
                    <TextBlock FontSize="16"
                               Foreground="{DynamicResource TextOnDarkBrush}"
                               Text="{loc:Localization Groups}" />
                </ListBoxItem>

                <!--  Info  -->
                <ListBoxItem Classes="nav-header"
                             IsEnabled="False">
                    <TextBlock Classes="label"
                               FontSize="13"
                               Foreground="{DynamicResource TextOnDarkBrush}"
                               Margin="20,28,20,4"
                               Opacity="0.4"
                               Text="{loc:Localization Info}" />
                </ListBoxItem>
                <ListBoxItem IsEnabled="{Binding !HasSettingsErrors}">
                    <TextBlock FontSize="16"
                               Foreground="{DynamicResource TextOnDarkBrush}"
                               Text="{loc:Localization Versions}" />
                </ListBoxItem>

            </ListBox>
        </Border>

        <!--  Content Area  -->
        <ContentControl Grid.Column="1"
                        Background="{DynamicResource AppBackgroundAltBrush}"
                        Content="{Binding CurrentPage}" />

    </Grid>
</Window>
