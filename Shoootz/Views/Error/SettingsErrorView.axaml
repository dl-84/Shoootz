<UserControl x:Class="Shoootz.Views.Error.SettingsErrorView"
             xmlns="https://github.com/avaloniaui"
             xmlns:jsonEditor="using:Controls.JsonEditor"
             xmlns:loc="using:Shoootz.Extensions"
             xmlns:vm="using:Shoootz.ViewModels.Error"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:DataType="vm:SettingsErrorViewModel">

    <Grid Margin="16,0,16,16"
          RowDefinitions="Auto,Auto,*,Auto">

        <!--  Header  -->
        <TextBlock Grid.Row="0"
                   Classes="h3"
                   Text="{loc:Localization SettingsFileError}" />

        <!--  Errors  -->
        <Border Grid.Row="1"
                Classes="card-error"
                Margin="0,16,0,0"
                IsVisible="{Binding !IsValid}">
            <StackPanel Spacing="8">
                <TextBlock Classes="on-dark"
                           FontWeight="SemiBold"
                           Text="{loc:Localization SettingsErrorHint}"
                           TextWrapping="Wrap" />
                <ItemsControl ItemsSource="{Binding ErrorMessages}"
                              IsVisible="{Binding ShowOriginalErrors}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Classes="on-dark"
                                       Text="{Binding}"
                                       TextWrapping="Wrap" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Classes="on-dark"
                           Text="{Binding ValidationError}"
                           TextWrapping="Wrap"
                           IsVisible="{Binding ShowValidationError}" />
            </StackPanel>
        </Border>

        <!--  Success  -->
        <Border Grid.Row="1"
                Classes="card-success"
                Margin="0,16,0,0"
                IsVisible="{Binding IsValid}">
            <StackPanel Spacing="4">
                <TextBlock Classes="on-dark"
                           FontWeight="SemiBold"
                           Text="{loc:Localization SettingsValidSuccess}" />
                <TextBlock Classes="on-dark"
                           Text="{loc:Localization SettingsValidSuccessHint}" />
            </StackPanel>
        </Border>

        <!--  Editor  -->
        <jsonEditor:JsonEditorControl x:Name="JsonEditor"
                                      Grid.Row="2"
                                      Margin="0,16,0,0"
                                      Text="{Binding EditorContent}" />

        <!--  Buttons  -->
        <StackPanel Grid.Row="3"
                    Margin="0,16,0,0"
                    Orientation="Horizontal"
                    Spacing="8">
            <Button Classes="green"
                    Command="{Binding ValidateCommand}"
                    Content="{loc:Localization Validate}" />
            <Button Classes="green"
                    Command="{Binding SaveCommand}"
                    Content="{loc:Localization Save}"
                    IsEnabled="{Binding IsValid}" />
            <Button Classes="green"
                    Command="{Binding RestartCommand}"
                    Content="{loc:Localization Restart}"
                    IsEnabled="{Binding IsSaved}" />
        </StackPanel>

    </Grid>

</UserControl>
