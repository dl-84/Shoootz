<UserControl x:Class="Shoootz.Views.Error.SettingsErrorView"
             xmlns="https://github.com/avaloniaui"
             xmlns:jsonEditor="using:Controls.JsonEditor"
             xmlns:loc="using:Shoootz.Extensions"
             xmlns:vm="using:Shoootz.ViewModels.Error"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:DataType="vm:SettingsErrorViewModel">

    <Grid Margin="16,0,16,16"
          RowDefinitions="Auto,Auto,*,Auto">

        <TextBlock Grid.Row="0"
                   Classes="h3"
                   Text="{loc:Localization SettingsFileError}" />

        <Border Grid.Row="1"
                Classes="card-error"
                Margin="0,16,0,0">
            <ItemsControl ItemsSource="{Binding ErrorMessages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Classes="on-dark"
                                   Text="{Binding}"
                                   TextWrapping="Wrap" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <jsonEditor:JsonEditorControl Grid.Row="2"
                                      Margin="0,16,0,0"
                                      Text="{Binding EditorContent}" />

        <StackPanel Grid.Row="3"
                    Margin="0,16,0,0"
                    Orientation="Horizontal"
                    Spacing="8">
            <Button Classes="large green"
                    Command="{Binding SaveCommand}"
                    Content="{loc:Localization SaveAndRestart}" />
            <Button Classes="large green"
                    Command="{Binding RestoreDefaultsCommand}"
                    Content="{loc:Localization RestoreDefaults}" />
        </StackPanel>

    </Grid>

</UserControl>
