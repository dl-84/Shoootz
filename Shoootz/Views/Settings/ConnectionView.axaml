<UserControl x:Class="Shoootz.Views.Settings.ConnectionView"
             xmlns="https://github.com/avaloniaui"
             xmlns:loc="using:Shoootz.Extensions"
             xmlns:vm="using:Shoootz.ViewModels.Settings"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:DataType="vm:ConnectionViewModel">

    <ScrollViewer>
        <StackPanel Classes="page-content">

            <!--  Header  -->
            <TextBlock Classes="h3"
                       Text="{loc:Localization Database}" />

            <Border Classes="card">
                <StackPanel Spacing="16">

                    <Grid ColumnDefinitions="Auto,*"
                          ColumnSpacing="8">

                        <!--  Provider  -->
                        <StackPanel Grid.Column="0"
                                    Spacing="2">
                            <TextBlock Classes="label"
                                       FontSize="13"
                                       Text="{loc:Localization Provider}" />
                            <ComboBox ItemsSource="{Binding ProviderOptions}"
                                      SelectedItem="{Binding SelectedProvider}"
                                      Width="170" />
                        </StackPanel>

                        <!--  Connection String + Buttons  -->
                        <StackPanel Grid.Column="1"
                                    Spacing="8">
                            <StackPanel Spacing="2">
                                <TextBlock Classes="label"
                                           FontSize="13"
                                           Text="{loc:Localization ConnectionString}" />
                                <TextBox Text="{Binding ConnectionString}" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                <Button Classes="green"
                                        Command="{Binding SaveCommand}"
                                        Content="{loc:Localization Save}" />
                                <Button Classes="green"
                                        Command="{Binding TestConnectionCommand}"
                                        Content="{loc:Localization TestConnection}" />
                            </StackPanel>
                        </StackPanel>

                    </Grid>

                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
