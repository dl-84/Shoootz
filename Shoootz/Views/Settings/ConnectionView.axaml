<UserControl x:Class="Shoootz.Views.Settings.ConnectionView"
             xmlns="https://github.com/avaloniaui"
             xmlns:loc="using:Shoootz.Extensions"
             xmlns:vm="using:Shoootz.ViewModels.Settings"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:DataType="vm:ConnectionViewModel">

    <Panel>

        <ScrollViewer>
            <StackPanel Classes="page-content">

                <!--  Datenbank  -->
                <Border Classes="card">
                    <StackPanel Spacing="16">

                        <TextBlock Classes="h4"
                                   Text="{loc:Localization Database}" />

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="8">

                            <!--  Provider  -->
                            <StackPanel Grid.Column="0"
                                        Spacing="2">
                                <TextBlock Classes="label"
                                           FontSize="13"
                                           Text="{loc:Localization Provider}" />
                                <ComboBox ItemsSource="{Binding ProviderOptions}"
                                          SelectedItem="{Binding SelectedProvider}"
                                          Width="170" />
                            </StackPanel>

                            <!--  Connection String + Test  -->
                            <StackPanel Grid.Column="1"
                                        Spacing="2">
                                <TextBlock Classes="label"
                                           FontSize="13"
                                           Text="{loc:Localization ConnectionString}" />
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="8">
                                    <TextBox Grid.Column="0"
                                             Text="{Binding ConnectionString}" />
                                    <Button Grid.Column="1"
                                            Classes="green icon"
                                            Command="{Binding TestConnectionCommand}"
                                            ToolTip.HorizontalOffset="0"
                                            ToolTip.Placement="TopEdgeAlignedRight"
                                            ToolTip.Tip="{loc:Localization TestConnection}"
                                            ToolTip.VerticalOffset="-2">
                                        <Image Height="24"
                                               Source="{Binding HeartPulseIcon}"
                                               Width="24" />
                                    </Button>
                                </Grid>
                            </StackPanel>

                        </Grid>

                    </StackPanel>
                </Border>

                <!--  UDP Broadcast  -->
                <Border Classes="card">
                    <StackPanel Spacing="16">

                        <TextBlock Classes="h4"
                                   Text="{loc:Localization UdpBroadcast}" />

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="8">

                            <!--  Port  -->
                            <StackPanel Grid.Column="0"
                                        Spacing="2">
                                <TextBlock Classes="label"
                                           FontSize="13"
                                           Text="{loc:Localization Port}" />
                                <TextBox Width="170" />
                            </StackPanel>

                            <!--  IP-Adresse  -->
                            <StackPanel Grid.Column="1"
                                        Spacing="2">
                                <TextBlock Classes="label"
                                           FontSize="13"
                                           Text="{loc:Localization IpAddress}" />
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="8">
                                    <TextBox Grid.Column="0" />
                                    <Button Grid.Column="1"
                                            Classes="green xsmall"
                                            Content="{loc:Localization Test}"
                                            ToolTip.Placement="TopEdgeAlignedRight"
                                            ToolTip.Tip="{loc:Localization TestConnection}" />
                                </Grid>
                            </StackPanel>

                        </Grid>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!--  Save  -->
        <Button Classes="green"
                Command="{Binding SaveCommand}"
                Content="{loc:Localization Save}"
                HorizontalAlignment="Right"
                Margin="0,0,20,20"
                VerticalAlignment="Bottom" />

    </Panel>
</UserControl>
