<UserControl x:Class="Shoootz.Views.Settings.ConnectionView"
             xmlns="https://github.com/avaloniaui"
             xmlns:loc="using:Shoootz.Extensions"
             xmlns:vm="using:Shoootz.ViewModels.Settings"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:DataType="vm:ConnectionViewModel">

    <Panel>

        <ScrollViewer>
            <StackPanel Classes="page-content">

                <!--  Datenbank  -->
                <Border Classes="card">
                    <StackPanel Spacing="{DynamicResource SpacingMedium}">

                        <TextBlock Classes="h4"
                                   Text="{loc:Localization Database}" />

                        <Grid ColumnDefinitions="Auto,*"
                              ColumnSpacing="{DynamicResource SpacingSmall}">

                            <!--  Provider  -->
                            <StackPanel Grid.Column="0"
                                        Spacing="{DynamicResource SpacingXSmall}">
                                <TextBlock Classes="label"
                                           Text="{loc:Localization Provider}" />
                                <ComboBox ItemsSource="{Binding ProviderOptions}"
                                          SelectedItem="{Binding SelectedProvider}"
                                          Width="170" />
                            </StackPanel>

                            <!--  Connection String + Test  -->
                            <StackPanel Grid.Column="1"
                                        Spacing="{DynamicResource SpacingXSmall}">
                                <TextBlock Classes="label"
                                           Text="{loc:Localization ConnectionString}" />
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="{DynamicResource SpacingSmall}">
                                    <TextBox Grid.Column="0"
                                             Text="{Binding ConnectionString}" />
                                    <Button Grid.Column="1"
                                            AutomationProperties.Name="{loc:Localization TestConnection}"
                                            Classes="green icon"
                                            Command="{Binding TestDbConnectionCommand}"
                                            ToolTip.HorizontalOffset="0"
                                            ToolTip.Placement="TopEdgeAlignedRight"
                                            ToolTip.Tip="{loc:Localization TestConnection}"
                                            ToolTip.VerticalOffset="-2">
                                        <Image Height="24"
                                               Source="{Binding HeartPulseIcon}"
                                               Width="24" />
                                    </Button>
                                </Grid>
                            </StackPanel>

                        </Grid>

                        <Grid ColumnDefinitions="*,Auto">
                            <Button Grid.Column="1"
                                    Classes="green"
                                    Command="{Binding InitializeDbCommand}"
                                    Content="{Binding InitializeDbLabel}" />
                        </Grid>

                    </StackPanel>
                </Border>

                <!--  UDP Broadcast  -->
                <Border Classes="card">
                    <StackPanel Spacing="{DynamicResource SpacingMedium}">

                        <TextBlock Classes="h4"
                                   Text="{loc:Localization UdpBroadcast}" />

                        <Grid ColumnDefinitions="*,170"
                              RowDefinitions="Auto,20,Auto"
                              RowSpacing="0">

                            <!--  AutoConnect  -->
                            <StackPanel Grid.Row="0"
                                        Grid.Column="0"
                                        Spacing="{DynamicResource SpacingXSmall}"
                                        VerticalAlignment="Top">
                                <TextBlock Classes="label"
                                           IsHitTestVisible="False"
                                           Opacity="0"
                                           Text="placeholder" />
                                <CheckBox Content="{loc:Localization AutoConnect}"
                                          FontSize="16"
                                          IsChecked="{Binding AutoConnect}" />
                            </StackPanel>

                            <!--  Port  -->
                            <StackPanel Grid.Row="0"
                                        Grid.Column="1"
                                        Spacing="{DynamicResource SpacingXSmall}">
                                <TextBlock Classes="label"
                                           Text="{loc:Localization Port}" />
                                <TextBox AutomationProperties.HelpText="{loc:Localization PortRangeHint}"
                                         Classes.error="{Binding !IsPortValid}"
                                         MaxLength="5"
                                         Text="{Binding Port}"
                                         loc:InputFilter.AllowedPattern="[0-9]"
                                         IsEnabled="{Binding !IsUdpListening}" />
                            </StackPanel>

                            <!--  Port error hint  -->
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Classes="hint-error"
                                       Margin="5,0,0,0"
                                       Text="{loc:Localization PortRangeHint}"
                                       IsVisible="{Binding !IsPortValid}" />

                            <!--  Start/Stop  -->
                            <Button Grid.Row="2"
                                    Grid.Column="1"
                                    Classes="green"
                                    Command="{Binding StartUdpCommand}"
                                    Content="{loc:Localization Start}"
                                    IsVisible="{Binding !IsUdpListening}" />
                            <Button Grid.Row="2"
                                    Grid.Column="1"
                                    Classes="danger"
                                    Command="{Binding StopUdpCommand}"
                                    Content="{loc:Localization Stop}"
                                    IsVisible="{Binding IsUdpListening}" />

                        </Grid>

                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!--  Save  -->
        <Button Classes="green"
                Command="{Binding SaveCommand}"
                Content="{loc:Localization Save}"
                HorizontalAlignment="Right"
                Margin="0,0,20,20"
                VerticalAlignment="Bottom" />

    </Panel>
</UserControl>
