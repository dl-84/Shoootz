<UserControl x:Class="Shoootz.Views.Settings.GroupsView"
             xmlns="https://github.com/avaloniaui"
             xmlns:loc="using:Shoootz.Extensions"
             xmlns:vm="using:Shoootz.ViewModels.Settings"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:DataType="vm:GroupsViewModel">
    <ScrollViewer>
        <StackPanel Classes="page-content">
            <TextBlock Classes="h3"
                       Text="{loc:Localization Groups}" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
