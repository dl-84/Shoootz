<UserControl x:Class="Shoootz.Views.Settings.GeneralView"
             xmlns="https://github.com/avaloniaui"
             xmlns:loc="using:Shoootz.Extensions"
             xmlns:models="using:Shoootz.Models"
             xmlns:vm="using:Shoootz.ViewModels.Settings"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:DataType="vm:GeneralViewModel">

    <ScrollViewer>
        <StackPanel Margin="16,32,16,32"
                    Spacing="16">

            <TextBlock Classes="h4"
                       Text="{loc:Localization Error}"
                       IsVisible="{Binding HasCriticalError}" />
            <Border Classes="card-error"
                    IsVisible="{Binding HasCriticalError}">
                <ScrollViewer MaxHeight="240">
                    <ItemsControl ItemsSource="{Binding CriticalErrorMessages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Classes="on-dark"
                                           Text="{Binding}"
                                           TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <TextBlock Classes="h4"
                       Text="{loc:Localization Language}"
                       IsEnabled="{Binding !HasCriticalError}" />
            <Border Classes="card"
                    IsEnabled="{Binding !HasCriticalError}">
                <StackPanel Spacing="12">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <Image Height="24"
                               Source="{Binding ErrorTriangle}"
                               VerticalAlignment="Center"
                               Width="24"
                               IsVisible="{Binding HasCurrentLanguageCodeError}" />
                        <ComboBox ItemsSource="{Binding LanguageOptions}"
                                  SelectedItem="{Binding SelectedLanguageOption}"
                                  Width="240">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="models:LanguageOptionModel">
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                VerticalAlignment="Center">
                                        <Image Height="24"
                                               Source="{Binding Flag}"
                                               VerticalAlignment="Center"
                                               Width="40" />
                                        <TextBlock Text="{Binding CultureInfo.NativeName}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <StackPanel Orientation="Horizontal"
                                    Spacing="4"
                                    VerticalAlignment="Center"
                                    IsVisible="{Binding HasCurrentLanguageCodeError}">
                            <TextBlock Classes="hint-error"
                                       FontSize="{DynamicResource FontSizeBody}"
                                       Text="{loc:Localization LanguageCodeInvalid}" />
                            <TextBlock Classes="hint-error"
                                       FontSize="{DynamicResource FontSizeBody}"
                                       FontWeight="Bold"
                                       Text="{Binding InvalidLanguageCodeValue}" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Classes="hint-error"
                               FontSize="{DynamicResource FontSizeBody}"
                               Text="{loc:Localization LanguageCodeInvalidHint}"
                               TextWrapping="Wrap"
                               IsVisible="{Binding HasCurrentLanguageCodeError}" />
                </StackPanel>
            </Border>

            <TextBlock Classes="h4"
                       Margin="0,16,0,0"
                       Text="{loc:Localization ConfigurationFile}"
                       IsEnabled="{Binding !HasValidationErrors}" />
            <Border Classes="card"
                    IsEnabled="{Binding !HasValidationErrors}">
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                    <Button Classes="green"
                            Command="{Binding OpenSettingsFolderCommand}"
                            Content="{loc:Localization OpenFolder}" />
                    <Button Classes="green"
                            Command="{Binding DeleteSettingsCommand}"
                            Content="{loc:Localization DeleteFile}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
