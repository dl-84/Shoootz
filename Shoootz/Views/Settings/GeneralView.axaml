<UserControl x:Class="Shoootz.Views.Settings.GeneralView"
             xmlns="https://github.com/avaloniaui"
             xmlns:loc="using:Shoootz.Extensions"
             xmlns:models="using:Shoootz.Models.Settings.Language"
             xmlns:vm="using:Shoootz.ViewModels.Settings"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:DataType="vm:GeneralViewModel">

    <ScrollViewer>
        <StackPanel Classes="page-content">

            <!--  Header  -->
            <TextBlock Classes="h3"
                       Text="{loc:Localization Database}" />

            <!--  Error  -->
            <Border Classes="card-error"
                    IsVisible="{Binding HasCriticalError}">
                <ScrollViewer MaxHeight="240">
                    <ItemsControl ItemsSource="{Binding CriticalErrorMessages}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Classes="on-dark"
                                           Text="{Binding}"
                                           TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!--  Language  -->
            <Border Classes="card"
                    IsEnabled="{Binding !HasCriticalError}">
                <StackPanel Spacing="12">
                    <StackPanel Spacing="2">
                        <TextBlock Classes="label"
                                   FontSize="13"
                                   Text="{loc:Localization Language}" />
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <Image Height="24"
                                   Source="{Binding ErrorTriangle}"
                                   VerticalAlignment="Center"
                                   Width="24"
                                   IsVisible="{Binding HasCurrentLanguageCodeError}" />
                            <ComboBox ItemsSource="{Binding LanguageOptions}"
                                      SelectedItem="{Binding SelectedLanguageOption}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:LanguageOptionModel">
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8"
                                                    VerticalAlignment="Center">
                                            <Image Height="24"
                                                   Source="{Binding Flag}"
                                                   VerticalAlignment="Center"
                                                   Width="40" />
                                            <TextBlock Text="{Binding CultureInfo.NativeName}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="4"
                                        VerticalAlignment="Center"
                                        IsVisible="{Binding HasCurrentLanguageCodeError}">
                                <TextBlock Classes="hint-error"
                                           FontSize="{DynamicResource FontSizeBody}"
                                           Text="{loc:Localization LanguageCodeInvalid}" />
                                <TextBlock Classes="hint-error"
                                           FontSize="{DynamicResource FontSizeBody}"
                                           FontWeight="Bold"
                                           Text="{Binding InvalidLanguageCodeValue}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Classes="hint-error"
                               FontSize="{DynamicResource FontSizeBody}"
                               Text="{loc:Localization LanguageCodeInvalidHint}"
                               TextWrapping="Wrap"
                               IsVisible="{Binding HasCurrentLanguageCodeError}" />
                </StackPanel>
            </Border>

            <!--  Setting Buttons  -->
            <TextBlock Classes="h4"
                       Text="{loc:Localization Settings}"
                       IsEnabled="{Binding !HasValidationErrors}" />

            <Border Classes="card"
                    IsEnabled="{Binding !HasValidationErrors}">
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                    <Button Classes="large green"
                            Command="{Binding OpenSettingsFolderCommand}"
                            Content="{loc:Localization OpenFolder}" />
                    <Button Classes="large green"
                            Command="{Binding ShowSettingsContentCommand}"
                            Content="{loc:Localization ShowSettings}" />
                </StackPanel>
            </Border>

            <!--  Danger Zone  -->
            <TextBlock Classes="h4"
                       Foreground="{DynamicResource ErrorBrush}"
                       Text="{loc:Localization DangerZone}"
                       IsEnabled="{Binding !HasValidationErrors}" />

            <Border Classes="card"
                    IsEnabled="{Binding !HasValidationErrors}">
                <StackPanel Orientation="Horizontal"
                            Spacing="8">
                    <Button Classes="danger large"
                            Command="{Binding DeleteSettingsFolderCommand}"
                            Content="{loc:Localization DeleteAll}" />
                    <Button Classes="danger large"
                            Command="{Binding DeleteSettingsFileCommand}"
                            Content="{loc:Localization DeleteSettingsFile}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
