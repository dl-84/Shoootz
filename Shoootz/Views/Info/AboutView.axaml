<UserControl x:Class="Shoootz.Views.Info.AboutView"
             xmlns="https://github.com/avaloniaui"
             xmlns:controls="using:Controls.LicenseTable"
             xmlns:loc="using:Shoootz.Extensions"
             xmlns:vm="using:Shoootz.ViewModels.Info"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:DataType="vm:AboutViewModel">

    <StackPanel Margin="32,0,32,32"
                Spacing="16">

        <TextBlock Classes="h4"
                   Text="{loc:Localization AboutTitle}" />

        <controls:LicenseTableControl HeaderBackgroundColor="{DynamicResource AccentGreenBrush}"
                                      HeaderFontColor="{DynamicResource AccentForegroundBrush}"
                                      Headers="{Binding ColumnHeaders}"
                                      Items="{Binding Packages}"
                                      LicenseContentRequested="OnLicenseContentRequested"
                                      PrimaryTextColor="{DynamicResource TextPrimaryBrush}"
                                      SecondaryTextColor="{DynamicResource TextMutedBrush}" />

    </StackPanel>

</UserControl>
