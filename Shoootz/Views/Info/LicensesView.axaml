
<UserControl x:Class="Shoootz.Views.Info.LicensesView"
             xmlns="https://github.com/avaloniaui"
             xmlns:controls="using:Controls.LicenseTable"
             xmlns:loc="using:Shoootz.Extensions"
             xmlns:vm="using:Shoootz.ViewModels.Info"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:DataType="vm:LicensesViewModel">

    <ScrollViewer>
        <StackPanel Classes="page-content">

            <TextBlock Classes="h4"
                       Text="{loc:Localization LicensesTitle}" />

            <controls:LicenseTableControl Headers="{Binding ColumnHeaders}"
                                          Items="{Binding Packages}" />

        </StackPanel>
    </ScrollViewer>

</UserControl>
