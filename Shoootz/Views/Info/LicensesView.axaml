
<UserControl x:Class="Shoootz.Views.Info.LicensesView"
             xmlns="https://github.com/avaloniaui"
             xmlns:controls="using:Controls.LicenseTable"
             xmlns:loc="using:Shoootz.Extensions"
             xmlns:vm="using:Shoootz.ViewModels.Info"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:DataType="vm:LicensesViewModel">

    <ScrollViewer>
        <StackPanel Margin="32,0,32,32"
                    Spacing="16">

            <TextBlock Classes="h4"
                       Text="{loc:Localization LicensesTitle}" />

            <controls:LicenseTableControl Items="{Binding Packages}"
                                          LicenseColumnHeader="{loc:Localization License}"
                                          LinkColumnHeader="{loc:Localization Link}"
                                          NameColumnHeader="{loc:Localization Name}"
                                          VersionColumnHeader="{loc:Localization Version}" />

        </StackPanel>
    </ScrollViewer>

</UserControl>
