<Window x:Class="Shoootz.Views.Dialogs.LicenseDialog"
        xmlns="https://github.com/avaloniaui"
        xmlns:loc="using:Shoootz.Extensions"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource AppBackgroundAltBrush}"
        CanResize="False"
        Height="650"
        Width="800"
        WindowDecorations="BorderOnly"
        WindowStartupLocation="CenterOwner">

    <Grid RowDefinitions="Auto,*,Auto">

        <Border Grid.Row="0"
                Background="{DynamicResource AccentGreenBrush}"
                Padding="24,12">
            <TextBlock Classes="label"
                       FontSize="16"
                       Foreground="{DynamicResource AccentForegroundBrush}"
                       Text="MIT License" />
        </Border>

        <TextBlock x:Name="LicenseTextBlock"
                   Grid.Row="1"
                   Margin="24,16,24,0"
                   TextWrapping="Wrap" />

        <Button Grid.Row="2"
                Classes="green"
                Click="OnCloseClicked"
                Content="{loc:Localization Close}"
                HorizontalAlignment="Center"
                Margin="0,16,0,24" />
    </Grid>
</Window>
