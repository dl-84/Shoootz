{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "IpAddress": {
      "type": "string",
      "pattern": "^((25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)\\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9][0-9]?)$"
    },
    "PortNumber": {
      "type": "integer",
      "minimum": 1,
      "maximum": 65535
    }
  },
  "type": "object",
  "properties": {
    "CurrentLanguageCode": {
      "enum": ["de", "en"]
    },
    "Database": {
      "type": "object",
      "properties": {
        "ConnectionString": {
          "type": "string"
        },
        "Provider": {
          "enum": ["PostgreSql", "Sqlite"]
        }
      },
      "required": ["ConnectionString", "Provider"],
      "additionalProperties": false
    },
    "UDP": {
      "type": "object",
      "properties": {
        "AutoConnect": {
          "type": "boolean"
        },
        "IpAddress": {
          "$ref": "#/definitions/IpAddress"
        },
        "Port": {
          "$ref": "#/definitions/PortNumber"
        }
      },
      "required": ["AutoConnect", "IpAddress", "Port"],
      "additionalProperties": false
    }
  },
  "required": ["CurrentLanguageCode", "Database", "UDP"],
  "additionalProperties": false
}
