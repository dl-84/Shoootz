<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Sektionsliga.ViewModels.Settings"
             xmlns:dtos="using:Sektionsliga.ViewModels.Settings.Dtos"
             x:Class="Sektionsliga.Views.Settings.GeneralView"
             x:DataType="vm:GeneralViewModel">

    <ScrollViewer>
        <StackPanel Margin="16,32,16,32" Spacing="16">

            <TextBlock Classes="h3" Text="Allgemein" />

            <Border Classes="card" CornerRadius="0">
                <StackPanel Spacing="12">
                    <TextBlock Classes="h4" Text="Anzeigesprache" />
                    <ComboBox ItemsSource="{x:Static vm:GeneralViewModel.LanguageOptions}"
                              SelectedItem="{Binding SelectedLanguageOption}"
                              Width="240">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="dtos:LanguageOptionDto">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <Image Source="{Binding Flag}" Width="40" Height="24" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding CultureInfo.NativeName}" VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>   
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
