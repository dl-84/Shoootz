<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Sektionsliga.ViewModels.Settings"
             x:Class="Sektionsliga.Views.Settings.GeneralView"
             x:DataType="vm:GeneralViewModel">

    <ScrollViewer>
        <StackPanel Margin="16,32,16,32" Spacing="16">

            <TextBlock Classes="h3" Text="Allgemein" />

            <Border Classes="card" CornerRadius="0">
                <StackPanel Spacing="12">
                    <TextBlock Classes="h4" Text="Anzeigesprache" />
                    <ComboBox ItemsSource="{Binding LanguageOptions}"
                              SelectedItem="{Binding SelectedLanguageOption}"
                              Width="240">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:LanguageOption">
                                <TextBlock Text="{Binding DisplayName}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>

</UserControl>
