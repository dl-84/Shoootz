<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Sektionsliga.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1200"
        d:DesignHeight="750"
        x:Class="Sektionsliga.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/Disag/Logo.png"
        Title="Sektionsliga"
        Width="1200"
        Height="750"
        MinWidth="900"
        MinHeight="600">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Resources>
        <ControlTheme x:Key="NavItemTheme" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="28,12,20,12" />
            <Setter Property="BorderThickness" Value="3,0,0,0" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
            <Setter Property="Opacity" Value="0.7" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="0"
                            Padding="28,12,20,12">
                        <TextBlock x:CompileBindings="False"
                                   Text="{Binding Label}"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextOnDarkBrush}" />
                    </Border>
                </ControlTemplate>
            </Setter>

            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="#1AFFFFFF" />
                <Setter Property="Opacity" Value="0.9" />
            </Style>
            <Style Selector="^:selected">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                <Setter Property="Background" Value="#2E019DC6" />
                <Setter Property="Opacity" Value="1" />
            </Style>
        </ControlTheme>
    </Window.Resources>

    <Grid ColumnDefinitions="220,*">

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource PrimaryBrush}">
            <StackPanel Margin="0,16,0,0">

                <!-- Competition -->
                <TextBlock Classes="label"
                           Text="WETTKAMPF"
                           Margin="20,16,20,4"
                           Foreground="{DynamicResource TextOnDarkBrush}"
                           Opacity="0.4" />
                <ListBox Background="Transparent"
                         BorderThickness="0"
                         CornerRadius="0"
                         Padding="0"
                         ItemsSource="{Binding CompetitionItems}"
                         SelectedItem="{Binding SelectedCompetitionItem}"
                         ItemContainerTheme="{StaticResource NavItemTheme}" />

                <!-- Settings -->
                <TextBlock Classes="label"
                           Text="EINSTELLUNGEN"
                           Margin="20,28,20,4"
                           Foreground="{DynamicResource TextOnDarkBrush}"
                           Opacity="0.4" />
                <ListBox Background="Transparent"
                         BorderThickness="0"
                         CornerRadius="0"
                         Padding="0"
                         ItemsSource="{Binding SettingsItems}"
                         SelectedItem="{Binding SelectedSettingsItem}"
                         ItemContainerTheme="{StaticResource NavItemTheme}" />

                <!-- Info -->
                <TextBlock Classes="label"
                           Text="INFO"
                           Margin="20,28,20,4"
                           Foreground="{DynamicResource TextOnDarkBrush}"
                           Opacity="0.4" />
                <ListBox Background="Transparent"
                         BorderThickness="0"
                         CornerRadius="0"
                         Padding="0"
                         ItemsSource="{Binding InfoItems}"
                         SelectedItem="{Binding SelectedInfoItem}"
                         ItemContainerTheme="{StaticResource NavItemTheme}" />

            </StackPanel>
        </Border>

        <!-- Content Area -->
        <ContentControl Grid.Column="1"
                        Content="{Binding CurrentPage}"
                        Background="{DynamicResource AppBackgroundAltBrush}" />

    </Grid>
</Window>
