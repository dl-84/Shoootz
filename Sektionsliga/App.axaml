<Application x:Class="Sektionsliga.App"
             xmlns="https://github.com/avaloniaui"
             xmlns:local="using:Sektionsliga"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             RequestedThemeVariant="Light">

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>